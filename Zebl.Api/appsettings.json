  },
  "Database": {
    "ApplyMigrationsAtStartup": true
  },
  "AuditTrail": {
    "IntegritySecret": ""
  },
  "JwtSettings": {
    "SecretKey": "YOUR_SECRET_KEY_HERE_MIN_32_CHARACTERS_FOR_HS256",
    "Issuer": "ZeblApi",
    "Audience": "ZeblApiUsers",
    "ExpirationMinutes": 60
  },
  "AdminUsers": [
    "admin"
  ],
  "CorsSettings": {
    "AllowedOrigins": [
      "https://zebl.netlify.app",
      "http://localhost:4200",
      "https://localhost:4200"
    ]
  },
  "RateLimiting": {
    "EnableRateLimiting": true,
    "PermitLimit": 100,
    "Window": "00:01:00"
  },
  "Encryption": {
    "Key": "YourEncryptionKeyMustBeAtLeast32CharactersLongForAES256"
  },
  "ClearinghouseSettings": {
    "Host": "",
    "Port": 22,
    "Username": "",
    "Password": "",
    "RemotePath": "/",
    "IncomingPath": "/",
    "ProcessedPath": "/processed",
    "EligibilityPollingMinutes": 2
  },
  "EdiOperational": {
    "ProcessingMetricSampleRate": 0.25
  },
  "EdiAdaptiveLimiter": {
    "InitialConcurrency": 8,
    "MinConcurrency": 2,
    "MaxConcurrency": 16,
    "ControlLoopIntervalMs": 2000,
    "ScaleUpStep": 1,
    "ScaleDownStep": 1,
    "CooldownTicks": 2,
    "CpuHighThreshold": 85.0,
    "CpuLowThreshold": 55.0,
    "MemoryHighThreshold": 0.85,
    "MemoryLowThreshold": 0.60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
